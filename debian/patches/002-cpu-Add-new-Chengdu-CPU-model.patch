From 299a26d3d0e67facf71c6935513760ce3eb68a86 Mon Sep 17 00:00:00 2001
From: Yongchen Lou <louyongchen@hygon.cn>
Date: Wed, 15 Oct 2025 08:55:54 +0000
Subject: [PATCH] cpu: Add new Chengdu CPU model

Add Hygon Chengdu CPU model to the processor model.

Signed-off-by: Yongchen Lou <louyongchen@hygon.cn>
---
 src/cpu_map/index.xml       |   1 +
 src/cpu_map/meson.build     |   1 +
 src/cpu_map/x86_Chengdu.xml | 100 ++++++++++++++++++++++++++++++++++++
 3 files changed, 102 insertions(+)
 create mode 100644 src/cpu_map/x86_Chengdu.xml

Index: libvirt/src/cpu_map/index.xml
===================================================================
--- libvirt.orig/src/cpu_map/index.xml
+++ libvirt/src/cpu_map/index.xml
@@ -75,6 +75,7 @@
     <!-- Hygon CPU models -->
     <include filename='x86_Dhyana.xml'/>
     <include filename='x86_Dharma.xml'/>
+    <include filename='x86_Chengdu.xml'/>
   </arch>
 
   <arch name='ppc64'>
Index: libvirt/src/cpu_map/meson.build
===================================================================
--- libvirt.orig/src/cpu_map/meson.build
+++ libvirt/src/cpu_map/meson.build
@@ -30,6 +30,7 @@ cpumap_data = [
   'x86_Broadwell.xml',
   'x86_Cascadelake-Server-noTSX.xml',
   'x86_Cascadelake-Server.xml',
+  'x86_Chengdu.xml',
   'x86_Conroe.xml',
   'x86_Cooperlake.xml',
   'x86_core2duo.xml',
Index: libvirt/src/cpu_map/x86_Chengdu.xml
===================================================================
--- /dev/null
+++ libvirt/src/cpu_map/x86_Chengdu.xml
@@ -0,0 +1,100 @@
+<cpus>
